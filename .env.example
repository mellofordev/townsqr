# Required.
# Use a Neon Postgres connection string, not localhost, because the app uses
# @neondatabase/serverless with drizzle-orm/neon-http.
DATABASE_URL=

# Required for stable Better Auth sessions.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required for Google OAuth login.
# Google redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
