# Required.
# Use a Neon Postgres connection string, not localhost, because the app uses
# @neondatabase/serverless with drizzle-orm/neon-http.
DATABASE_URL=

# Required for stable Better Auth sessions.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required for Google OAuth login.
# Google redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required when sending email through Resend.
# In deployed Workers, set this with: wrangler secret put RESEND_API_KEY
RESEND_API_KEY=

# Must be an address from the verified Resend domain.
TOWNSQR_EMAIL_FROM=

# Optional. Set to false locally to explicitly skip outbound email.
TOWNSQR_EMAIL_ENABLED=true
